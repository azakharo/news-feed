{
  "name": "news-feed-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && npm run build:migrations",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev:testui": "dotenv -e .env.test -- nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "ts": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.test -- jest --config ./test/jest-e2e.json",
    "test:db:create": "ts-node -r tsconfig-paths/register scripts/create-test-db.ts",
    "test:db:migrate": "dotenv -e .env.test -- ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "test:setup": "npm run test:db:create && npm run test:db:migrate && npm run db:seed:test",
    "build:migrations": "tsc -p tsconfig.build.json",
    "migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create -d src/data-source.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
    "migration:show": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d src/data-source.ts",
    "db:seed:test": "dotenv -e .env.test -- ts-node -r tsconfig-paths/register src/database/run-seed.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/run-seed.ts",
    "db:reset": "ts-node -r tsconfig-paths/register src/database/reset-db.ts",
    "migration:run:prod": "typeorm migration:run -d dist/data-source.js",
    "migration:revert:prod": "typeorm migration:revert -d dist/data-source.js",
    "migration:show:prod": "typeorm migration:show -d dist/data-source.js",
    "db:seed:prod": "node dist/database/run-seed.js"
  },
  "dependencies": {
    "@keyv/redis": "5.1.6",
    "@nestjs/cache-manager": "3.1.0",
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.17",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/platform-express": "11.1.17",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/typeorm": "11.0.0",
    "cache-manager": "7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "keyv": "5.6.0",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.28"
  },
  "overrides": {
    "@nestjs/mapped-types": "2.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.17",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.17",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.15",
    "@types/supertest": "6.0.3",
    "dotenv-cli": "11.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
